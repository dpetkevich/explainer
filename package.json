{
  "name": "explain-it",
  "version": "0.1.0",
  "description": "Turn a scientific paper (PDF) or technical article (URL) into a self-contained interactive HTML explainer",
  "type": "module",
  "bin": {
    "explain-it": "./bin/explain-it.js"
  },
  "scripts": {
    "typecheck": "tsc --noEmit",
    "start": "tsx src/cli.ts",
    "serve": "tsx src/server/index.ts"
  },
  "engines": {
    "node": ">=20"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.39.0",
    "@fastify/multipart": "^10.1.0",
    "@fastify/static": "^10.1.0",
    "@mozilla/readability": "^0.5.0",
    "better-sqlite3": "^12.11.1",
    "commander": "^12.1.0",
    "fastify": "^5.10.0",
    "jsdom": "^24.1.0",
    "playwright": "^1.48.0",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.13",
    "@types/jsdom": "^21.1.7",
    "@types/node": "^20.14.0",
    "tsx": "^4.19.0",
    "typescript": "^5.6.0"
  }
}
